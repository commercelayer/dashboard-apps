{
  "name": "app-imports",
  "description": "A Commerce Layer Single Page Application to import resources with a nice GUI.",
  "version": "4.6.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "keywords": [
    "reactjs",
    "jamstack",
    "headless",
    "ecommerce",
    "api",
    "imports",
    "commercelayer"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "pnpm biome check",
    "check:fix": "pnpm biome check --write",
    "ts:check": "tsc --noEmit",
    "test": "pnpm run check && vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests"
  },
  "dependencies": {
    "@commercelayer/app-elements": "7.7.6",
    "@commercelayer/sdk": "6.57.0",
    "@vitejs/plugin-react": "^5.2.0",
    "dashboard-apps-common": "workspace:*",
    "lodash-es": "^4.18.1",
    "papaparse": "^5.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-select": "^5.10.2",
    "wouter": "^3.10.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@commercelayer/app-builder": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "22.13.4",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "i18next": "^25.10.10",
    "jsdom": "^27.4.0",
    "rollup-plugin-external-globals": "^0.13.0",
    "type-fest": "^5.7.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
